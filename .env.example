# Repository-level environment template.
# Copy to `.env` (gitignored) to override defaults locally.

# Directory where session JSON files are persisted by the backend.
# Production (docker-compose): bound to the `archery-data` named volume at /data.
# Local dev outside Docker:    override to a writable path, e.g. ./local-data
DATA_DIR=/data

# Host path containing `update-application-dock-docker.sh` (used by the Settings
# "Update applications" button). Set to the absolute path on the host machine.
# When unset, the Settings button shows "Update not available" (graceful degradation).
# Example: HOST_SCRIPTS_DIR=/home/jake/scripts
HOST_SCRIPTS_DIR=/scripts
