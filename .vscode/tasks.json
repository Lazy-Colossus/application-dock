{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Mac Backend: dev server",
      "type": "shell",
      "command": "${workspaceFolder}/backend/.venv/bin/uvicorn app.main:app --reload --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "DATA_DIR": "./local-data"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "uvicorn",
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Started server process.*|.*Will watch for changes.*",
          "endsPattern": ".*Application startup complete.*|.*Uvicorn running on.*"
        }
      },
      "presentation": {
        "group": "app",
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Mac Frontend: dev server",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "env": {
          "PATH": "/usr/local/bin:${env:PATH}"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "quasar",
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*App •.*|.*Compiling.*|.*starting.*",
          "endsPattern": ".*App URL.*|.*ready in.*|.*Compiled.*"
        }
      },
      "presentation": {
        "group": "app",
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Mac Launch App",
      "dependsOn": [
        "Mac Backend: dev server",
        "Mac Frontend: dev server"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Win Start Backend",
      "type": "shell",
      "command": "$env:DATA_DIR='./local-data'; ..\\.venv\\Scripts\\uvicorn.exe app.main:app --reload --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "presentation": {
        "group": "dev",
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "Win Start Frontend",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "group": "dev",
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "Win Start Dev (BE + FE)",
      "dependsOn": [
        "Win Start Backend",
        "Win Start Frontend"
      ],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always"
      },
      "problemMatcher": []
    }
  ]
}